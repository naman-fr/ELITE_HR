# --- ELITE HR Intelligence Platform Configuration ---

# Application
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI Layer (OpenAI or Groq)
# Groq keys start with gsk_ and auto-route to llama-3.3-70b-versatile
OPENAI_API_KEY=your_groq_or_openai_key_here
CHAT_RATE_LIMIT=30/minute
MAX_UPLOAD_BYTES=10485760

# Data paths (optional — auto-detected in Docker)
MASTER_EXCEL_PATH=

# Security Layer (Wazuh XDR)
WAZUH_API_URL=https://your-wazuh-manager:55000
WAZUH_API_USER=admin
WAZUH_API_PASSWORD=your_wazuh_password
# Optional cloud token alternative to user/password
WAZUH_API_KEY=

# Identity Layer (Keycloak IAM)
KEYCLOAK_URL=https://keycloak.company.com
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=hr-platform
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret

# Frontend (required for split docker-compose deployment)
NEXT_PUBLIC_API_URL=http://localhost:8000
